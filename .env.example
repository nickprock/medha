# =============================================================================
# Medha - Semantic Cache Configuration
# =============================================================================
# Copy this file to .env and adjust values as needed.
# All MEDHA_ variables are loaded automatically via pydantic-settings.

# --- Backend selection ---
# MEDHA_BACKEND_TYPE=memory         # default - pure Python, no external deps
# MEDHA_BACKEND_TYPE=qdrant         # pip install medha[qdrant]
# MEDHA_BACKEND_TYPE=pgvector       # pip install medha[pgvector]
# MEDHA_BACKEND_TYPE=vectorchord    # pip install medha[vectorchord]
# MEDHA_BACKEND_TYPE=elasticsearch  # pip install medha[elasticsearch]
# MEDHA_BACKEND_TYPE=chroma         # pip install medha[chroma]
# MEDHA_BACKEND_TYPE=weaviate       # pip install medha[weaviate]
# MEDHA_BACKEND_TYPE=redis          # pip install medha[redis]
# MEDHA_BACKEND_TYPE=azure-search   # pip install medha[azure-search]
# MEDHA_BACKEND_TYPE=lancedb        # pip install medha[lancedb]

# --- Query Language ---
MEDHA_QUERY_LANGUAGE=generic        # sql | cypher | graphql | generic

# --- Search Thresholds ---
MEDHA_SCORE_THRESHOLD_EXACT=0.99
MEDHA_SCORE_THRESHOLD_SEMANTIC=0.85
MEDHA_SCORE_THRESHOLD_TEMPLATE=0.70
MEDHA_SCORE_THRESHOLD_FUZZY=85.0
MEDHA_SCORE_THRESHOLD_FUZZY_PREFILTER=0.65  # vector pre-filter for fuzzy candidates
MEDHA_FUZZY_PREFILTER_TOP_K=50              # max candidates for fuzzy pre-filtering

# --- L1 Cache ---
MEDHA_L1_CACHE_MAX_SIZE=1000        # 0 = disabled

# --- Batch Operations ---
MEDHA_BATCH_SIZE=100
MEDHA_BATCH_EMBED_CONCURRENCY=1     # concurrent embedding chunks in store_many()

# --- Cache Lifecycle (TTL) ---
# MEDHA_DEFAULT_TTL_SECONDS=3600    # None = immortal entries
# MEDHA_CLEANUP_INTERVAL_SECONDS=   # None = no automatic cleanup (min: 60)

# --- Input Validation ---
MEDHA_MAX_QUESTION_LENGTH=8192      # max chars per question (DoS protection)

# --- File Operations ---
# MEDHA_ALLOWED_FILE_DIR=           # restrict warm_from_file() to this directory
MEDHA_MAX_FILE_SIZE_MB=100

# --- Template Loading ---
# MEDHA_TEMPLATE_FILE=              # path to JSON template file

# --- Persistent Embedding Cache ---
# MEDHA_EMBEDDING_CACHE_PATH=       # path to JSON file for cross-restart embedding cache

# --- Embedding Timeout ---
# MEDHA_EMBEDDING_TIMEOUT=          # seconds (None = no timeout)

# --- Observability ---
MEDHA_COLLECT_STATS=true
MEDHA_STATS_MAX_LATENCY_SAMPLES=10000

# =============================================================================
# Qdrant Backend  (MEDHA_BACKEND_TYPE=qdrant)
# =============================================================================
# MEDHA_QDRANT_MODE=memory            # memory | docker | cloud
# MEDHA_QDRANT_HOST=localhost
# MEDHA_QDRANT_PORT=6333
# MEDHA_QDRANT_URL=                 # full URL, overrides host:port
# MEDHA_QDRANT_API_KEY=             # required for cloud mode

# --- HNSW & Quantization Tuning (Qdrant) ---
# MEDHA_HNSW_M=16
# MEDHA_HNSW_EF_CONSTRUCT=100
# MEDHA_ENABLE_QUANTIZATION=true
# MEDHA_QUANTIZATION_TYPE=scalar      # scalar | binary (binary requires dim >= 512)
# MEDHA_ON_DISK=false

# --- Quantization Search Parameters (Qdrant) ---
# MEDHA_QUANTIZATION_RESCORE=true
# MEDHA_QUANTIZATION_OVERSAMPLING=  # e.g. 2.0
# MEDHA_QUANTIZATION_IGNORE=false
# MEDHA_QUANTIZATION_ALWAYS_RAM=true

# =============================================================================
# PostgreSQL / pgvector Backend  (MEDHA_BACKEND_TYPE=pgvector)
# =============================================================================
# MEDHA_PG_DSN=postgresql://postgres:password@localhost:5432/medha
# --- or individual fields: ---
# MEDHA_PG_HOST=localhost
# MEDHA_PG_PORT=5432
# MEDHA_PG_DATABASE=medha
# MEDHA_PG_USER=postgres
# MEDHA_PG_PASSWORD=secret
# MEDHA_PG_SCHEMA=public
# MEDHA_PG_TABLE_PREFIX=medha
# MEDHA_PG_POOL_MIN_SIZE=2
# MEDHA_PG_POOL_MAX_SIZE=10

# =============================================================================
# VectorChord Backend  (MEDHA_BACKEND_TYPE=vectorchord)
# Uses same PG_* connection variables as pgvector above.
# =============================================================================
# MEDHA_VC_LISTS=[1000]             # centroids per level (JSON list)
# MEDHA_VC_RESIDUAL_QUANTIZATION=true

# =============================================================================
# Elasticsearch Backend  (MEDHA_BACKEND_TYPE=elasticsearch)
# =============================================================================
# MEDHA_ES_HOSTS=["http://localhost:9200"]  # JSON list of node URLs
# MEDHA_ES_API_KEY=                  # Elasticsearch API key
# MEDHA_ES_USERNAME=                 # basic-auth username (alternative to API key)
# MEDHA_ES_PASSWORD=                 # basic-auth password
# MEDHA_ES_INDEX_PREFIX=medha
# MEDHA_ES_NUM_CANDIDATES=100        # kNN num_candidates
# MEDHA_ES_TIMEOUT=30.0              # request timeout in seconds

# =============================================================================
# Chroma Backend  (MEDHA_BACKEND_TYPE=chroma)
# =============================================================================
# MEDHA_CHROMA_MODE=ephemeral        # ephemeral | persistent | http
# MEDHA_CHROMA_HOST=localhost        # http mode only
# MEDHA_CHROMA_PORT=8000             # http mode only
# MEDHA_CHROMA_PERSIST_PATH=         # persistent mode: local directory
# MEDHA_CHROMA_SSL=false             # http mode only
# MEDHA_CHROMA_AUTH_TOKEN=           # http mode bearer token

# =============================================================================
# Weaviate Backend  (MEDHA_BACKEND_TYPE=weaviate)
# =============================================================================
# MEDHA_WEAVIATE_MODE=local          # local | cloud
# MEDHA_WEAVIATE_HOST=localhost      # local mode
# MEDHA_WEAVIATE_HTTP_PORT=8080      # local mode
# MEDHA_WEAVIATE_GRPC_PORT=50051     # local mode
# MEDHA_WEAVIATE_HTTP_SECURE=false
# MEDHA_WEAVIATE_GRPC_SECURE=false
# MEDHA_WEAVIATE_CLOUD_URL=          # cloud mode cluster URL
# MEDHA_WEAVIATE_API_KEY=            # required for cloud mode
# MEDHA_WEAVIATE_COLLECTION_PREFIX=Medha

# =============================================================================
# Redis Stack Backend  (MEDHA_BACKEND_TYPE=redis)
# =============================================================================
# MEDHA_REDIS_MODE=standalone        # standalone | sentinel
# MEDHA_REDIS_URL=                   # full URL, overrides host/port/db
# MEDHA_REDIS_HOST=localhost
# MEDHA_REDIS_PORT=6379
# MEDHA_REDIS_DB=0
# MEDHA_REDIS_USERNAME=              # ACL username
# MEDHA_REDIS_PASSWORD=
# MEDHA_REDIS_SSL=false
# MEDHA_REDIS_SSL_CERTFILE=          # path to client TLS cert
# MEDHA_REDIS_SSL_KEYFILE=           # path to client TLS key
# MEDHA_REDIS_SSL_CA_CERTS=          # path to CA bundle
# MEDHA_REDIS_SENTINEL_HOSTS=["localhost:26379"]  # sentinel mode
# MEDHA_REDIS_SENTINEL_MASTER=mymaster
# MEDHA_REDIS_KEY_PREFIX=medha
# MEDHA_REDIS_INDEX_ALGORITHM=HNSW   # HNSW | FLAT
# MEDHA_REDIS_HNSW_M=16
# MEDHA_REDIS_HNSW_EF_CONSTRUCTION=200
# MEDHA_REDIS_HNSW_EF_RUNTIME=10
# MEDHA_REDIS_SOCKET_TIMEOUT=5.0
# MEDHA_REDIS_SOCKET_CONNECT_TIMEOUT=5.0

# =============================================================================
# Azure AI Search Backend  (MEDHA_BACKEND_TYPE=azure-search)
# =============================================================================
# MEDHA_AZURE_SEARCH_ENDPOINT=https://my-service.search.windows.net
# MEDHA_AZURE_SEARCH_API_KEY=        # if not set, uses DefaultAzureCredential
# MEDHA_AZURE_SEARCH_API_VERSION=2024-05-01-preview
# MEDHA_AZURE_SEARCH_INDEX_NAME=medha
# MEDHA_AZURE_SEARCH_TOP_K_CANDIDATES=50

# =============================================================================
# LanceDB Backend  (MEDHA_BACKEND_TYPE=lancedb)
# =============================================================================
# MEDHA_LANCEDB_URI=./lancedb_data   # local path or s3:// / gs:// / az://
# MEDHA_LANCEDB_TABLE_PREFIX=medha
# MEDHA_LANCEDB_METRIC=cosine        # cosine | l2 | dot

# =============================================================================
# NER / Parameter Extraction
# =============================================================================
# ParameterExtractor supports two NER backends (configured at construction time,
# not via env vars). Install the one you need:
#
#   spaCy  (pre-trained, label-mapped, ~15 MB model):
#     pip install medha[nlp]
#     python -m spacy download en_core_web_sm
#
#   GLiNER (zero-shot, uses template param names as labels directly, ~500 MB):
#     pip install medha[gliner]
#     # model is auto-downloaded from HuggingFace on first use
#
# Usage in code:
#   ParameterExtractor(use_spacy=True)
#   ParameterExtractor(use_gliner=True)
#   ParameterExtractor(use_spacy=True, use_gliner=True)
#   ParameterExtractor(use_gliner=True, gliner_model="urchade/gliner_small-v2.1")

# =============================================================================
# External API Keys
# =============================================================================
# OPENAI_API_KEY=                    # required only when using OpenAIAdapter